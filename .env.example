# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/cashyloot?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# Public (exposed to browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare Turnstile
# Use test keys for local dev (always passes): https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# SES (Email) — note: Amplify doesn't allow AWS_ prefix in env vars
SES_REGION="us-east-1"
SES_FROM_EMAIL="noreply@cashyloot.com"

# Offerwall Providers (Phase 2 — after approval)
# ADGEM_API_KEY=""
# ADGEM_POSTBACK_SECRET=""
# LOOTABLY_API_KEY=""
# LOOTABLY_POSTBACK_SECRET=""
# BITLABS_API_KEY=""
# BITLABS_POSTBACK_SECRET=""

# Payout Providers (Phase 3)
# TREMENDOUS_API_KEY=""
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
