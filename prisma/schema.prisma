generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Better Auth Core Tables
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Custom fields for CashyLoot
  balance          Int       @default(0) // Points balance (100 points = $1.00)
  dateOfBirth      DateTime?
  status           String    @default("active") // active, suspended, banned
  ipAddress        String?
  deviceFingerprint String?

  sessions     Session[]
  accounts     Account[]
  transactions  Transaction[]
  withdrawals   Withdrawal[]
  fraudEvents   FraudEvent[]
  vaultOpenings VaultOpening[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ============================================
// CashyLoot Application Tables
// ============================================

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  type       String   // "earn" or "withdraw"
  amount     Int      // Points amount
  provider   String?  // "adgem", "lootably", "bitlabs" (for earn type)
  campaignId String?
  status     String   @default("completed") // completed, pending, reversed
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("transaction")
}

model Withdrawal {
  id            String    @id @default(cuid())
  userId        String
  method        String    // "paypal" or "gift_card"
  amountPoints  Int
  amountUsd     Float
  paypalEmail   String?
  giftCardType  String?   // "amazon", "visa", "steam", etc.
  status        String    @default("pending") // pending, processing, completed, failed
  processedAt   DateTime?
  payoutProvider String?  // "tremendous" or "paypal"
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("withdrawal")
}

model PostbackLog {
  id         String   @id @default(cuid())
  rawPayload String   @db.Text
  provider   String   // "adgem", "lootably", "bitlabs"
  playerId   String?
  requestId  String?  @unique // For deduplication
  verified   Boolean  @default(false)
  processed  Boolean  @default(false)
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([provider])
  @@index([requestId])
  @@map("postback_log")
}

model FraudEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String   // "rate_limit", "duplicate_postback", "vpn_detected", "multi_account", etc.
  details   String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@map("fraud_event")
}

model VaultOpening {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String   // "bronze" | "silver" | "gold"
  cost      Int      // points spent
  prize     Int      // points won
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("vault_opening")
}

// ============================================
// Better Auth Built-in Rate Limiter Storage
// ============================================
// Used when `rateLimit.storage = "database"` is set in auth.ts.
// Better Auth's adapter looks up rows by `key` (format: "${ip}:${path}") and
// increments `count` within each rolling window. `lastRequest` is a ms-epoch
// timestamp used to compute whether the window has elapsed.
//
// Schema fields are fixed by Better Auth's storage contract — do not rename.
// See: @better-auth/core/dist/db/get-tables.mjs for the authoritative shape.

model RateLimit {
  id          String @id @default(cuid())
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("rate_limit")
}

// ============================================
// Application-Level Rate Limiter Storage
// ============================================
// Separate from Better Auth's RateLimit table on purpose: this one is
// managed entirely by our own code (src/lib/rate-limit.ts) and has a
// different schema shape. Better Auth owns its rate_limit table; we own
// this one. Two tables means zero risk of schema conflicts when Better
// Auth updates its storage contract.
//
// Used for business-logic rate limits that Better Auth doesn't know how
// to express: per-user vault opens, future per-user withdraw limits,
// per-provider offerwall postback limits, etc.
//
// Key format is caller-chosen, e.g. "vault-open:user:${userId}". The
// fixed-window approach is simple and correct under concurrency via
// Postgres INSERT ... ON CONFLICT row locking — see the helper source
// for the exact upsert pattern.

model AppRateLimit {
  key         String @id
  count       Int    @default(1)
  windowStart BigInt @map("window_start") // ms-epoch timestamp
  updatedAt   BigInt @map("updated_at")   // ms-epoch timestamp, for cleanup jobs

  @@index([updatedAt])
  @@map("app_rate_limit")
}

// ============================================
// IP Intelligence Cache
// ============================================
// Cached results from proxycheck.io (free tier: 1,000 lookups/day).
// IPs don't change classification frequently, so 24h TTL is fine.
// The cache avoids burning API quota on repeat visits from the same IP.
// Lookup happens on login (session.create.after hook in auth.ts).

model IpIntelCache {
  ip        String   @id
  isVpn     Boolean  @default(false)
  isProxy   Boolean  @default(false)
  type      String?  // "VPN", "Residential", "Datacenter", "Web Proxy"
  provider  String?  // "NordVPN", "ExpressVPN", etc.
  country   String?  // ISO 3166-1 alpha-2: "US", "GB"
  riskLevel String   @default("low") @map("risk_level") // "low", "medium", "high"
  checkedAt DateTime @default(now()) @map("checked_at")

  @@index([checkedAt])
  @@map("ip_intel_cache")
}
